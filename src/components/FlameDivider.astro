<div class="flame" aria-hidden="true">
  <span class="f">🔥</span>
  <span class="f">🔥</span>
</div>

<style>
  .flame {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin: 8px 0;
  }
  .flame::before, .flame::after {
    content: "";
    height: 0;
    flex: 1;
    border-top: 2px dashed var(--color-hr);
  }
  .flame .f {
    font-size: 26px;
    animation: pulse 1.5s ease-in-out infinite;
  }
  .flame .f:nth-child(2) {
    animation-delay: .25s;
  }
</style>
